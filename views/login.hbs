<div class="login-container">

    <h1 class="login-title">
        INICIO DE SESIÓN
    </h1>

    <form action="/login" method="POST" class="login-form">

        <div class="form-row">

            <label for="username">
                Usuario:
            </label>

            <input
                type="text"
                id="username"
                name="username"
                required
            >

        </div>

        <div class="form-row">

            <label for="password">
                Contraseña:
            </label>

            <input
                type="password"
                id="password"
                name="password"
                required
            >

        </div>

        <button type="submit" class="btn-login">
            INICIAR SESIÓN
        </button>

    </form>

    <img src="/media/momo.png" class="miku-left">
    <img src="/media/miku.png" class="miku-right">

</div>