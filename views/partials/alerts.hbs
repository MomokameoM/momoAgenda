{{#if success}}

    <div
        class="alert alert-success alert-dismissible fade show position-fixed top-0 end-0 m-3"
        role="alert"
    >

        {{success}}

        <button
            type="button"
            class="btn-close"
            data-bs-dismiss="alert"
        ></button>

    </div>

{{/if}}



{{#if error}}

    <div
        class="alert alert-danger alert-dismissible fade show position-fixed top-0 end-0 m-3"
        role="alert"
    >

        {{error}}

        <button
            type="button"
            class="btn-close"
            data-bs-dismiss="alert"
        ></button>

    </div>

{{/if}}