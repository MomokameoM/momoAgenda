<div class="materias-container">

```
<h1 class="titulo-materias">
    MATERIAS DE {{username}}
</h1>

<div class="materias-layout">

    <!-- TABLA -->

    <div class="materias-tabla">

        <p class="subtitulo-materias">
            AQUÍ PUEDES VER TUS MATERIAS
        </p>

        <table class="tabla-materias">

            <thead>

                <tr>

                    <th>MATERIA</th>
                    <th>PROFESOR</th>
                    <th>ACCIONES</th>

                </tr>

            </thead>

            <tbody>

                {{#each materias}}

                <tr>

                    <td>

                        <span
                            class="badge"
                            style="
                                background-color:
                                {{this.color}};
                                color:white;
                            "
                        >

                            {{this.nombre}}

                        </span>

                    </td>

                    <td>
                        {{this.profesor}}
                    </td>

                    <td class="acciones">

                        <a
                            href="/materias/editar/{{this.id}}"
                            class="btn-editar"
                        >
                            EDITAR
                        </a>

                        <form
                            action="/materias/eliminar/{{this.id}}"
                            method="POST"
                        >

                            <button
                                type="submit"
                                class="btn-eliminar"
                            >
                                ELIMINAR
                            </button>

                        </form>

                    </td>

                </tr>

                {{/each}}

            </tbody>

        </table>

    </div>

    <!-- PANEL DERECHO -->

    <div class="materias-panel">

        <h3 class="subtitulo-materias">
            AGREGAR MATERIA
        </h3>

        <a href="/materias/nueva">

            <button
                class="btn-crear-principal"
            >
                CREAR
            </button>

        </a>

    </div>

</div>
```

