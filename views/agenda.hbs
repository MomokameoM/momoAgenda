<div class="agenda-container">

```
<h1 class="titulo-agenda">
    AGENDA DE {{username}}
</h1>

<div class="agenda-layout">

    <!-- TABLA -->

    <div class="agenda-tabla">

        <p class="subtitulo-agenda">
            AQUÍ PUEDES VER TU AGENDA
        </p>

        <table class="tabla-agenda">

            <thead>

                <tr>

                    <th>FECHA</th>
                    <th>MATERIA</th>
                    <th>TAREA</th>
                    <th>ESTADO</th>
                    <th>ACCIONES</th>

                </tr>

            </thead>

            <tbody>

                {{#each agenda}}

                <tr {{#if this.vencida}} class="fila-vencida" {{/if}}>

                    <td>
                        {{formatDate this.fecha_entrega}}
                    </td>

                    <td>

                        <span
                            class="badge"
                            style="
                                background-color:
                                {{this.color}};
                                color:white;
                            "
                        >

                            {{this.materia}}

                        </span>

                    </td>

                    <td>
                        {{this.titulo}}
                    </td>

                    <td>

                        {{#if (eq this.estado "completada")}}

                            <span class="estado-completada">
                                Completada
                            </span>

                        {{else}}

                            {{#if this.vencida}}

                                <span class="estado-vencida">
                                    Vencida
                                </span>

                            {{else}}

                                <span class="estado-pendiente">
                                    Pendiente
                                </span>

                            {{/if}}

                        {{/if}}

                    </td>

                    <td class="acciones">

                        <form
                            action="/agenda/toggleEstado/{{this.id}}"
                            method="POST"
                        >

                            {{#if (eq this.estado "pendiente")}}

                                <button
                                    type="submit"
                                    class="btn-completar"
                                >
                                    COMPLETAR
                                </button>

                            {{else}}

                                <button
                                    type="submit"
                                    class="btn-reabrir"
                                >
                                    REABRIR
                                </button>

                            {{/if}}

                        </form>

                        <a
                            href="/agenda/editar/{{this.id}}"
                            class="btn-editar"
                        >
                            EDITAR
                        </a>

                        <form
                            action="/agenda/eliminar/{{this.id}}"
                            method="POST"
                        >

                            <button
                                type="submit"
                                class="btn-eliminar"
                            >
                                ELIMINAR
                            </button>

                        </form>

                    </td>

                </tr>

                {{/each}}

            </tbody>

        </table>

    </div>

    <!-- FORMULARIO -->

    <div class="agenda-formulario">

        <h3 class="subtitulo-agenda">
            AGREGAR TAREA
        </h3>

        <a href="/agenda/nueva">

            <button
                class="btn-crear-principal"
            >
                CREAR
            </button>

        </a>

    </div>

</div>
```

