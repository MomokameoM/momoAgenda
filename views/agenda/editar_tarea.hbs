<h1>Editar tarea</h1>

<form
    action="/agenda/editar/{{tarea.id}}"
    method="POST"
>

    <input
        type="text"
        name="titulo"
        value="{{tarea.titulo}}"
        required
    >

    <br><br>

    <textarea
        name="descripcion"
    >{{tarea.descripcion}}</textarea>

    <br><br>

    <select name="materia_id">

        {{#each materias}}

        <option
            value="{{this.id}}"
        >
            {{this.nombre}}
        </option>

        {{/each}}

    </select>

    <br><br>

    <input
        type="datetime-local"
        name="fecha_entrega"
        value="{{tarea.fecha_entrega}}"
    >

    <br><br>

    <select name="estado">

        <option value="pendiente">
            Pendiente
        </option>

        <option value="completada">
            Completada
        </option>

    </select>

    <br><br>

    <button type="submit">
        Guardar cambios
    </button>

</form>