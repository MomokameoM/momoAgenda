<div class="formulario-momo">

<h1 class="titulo-formulario">
    EDITAR TAREA
</h1>

<form
    action="/agenda/editar/{{tarea.id}}"
    method="POST"
    class="form-momo"
>

    <div class="campo-momo">

        <label>
            TÍTULO
        </label>

        <input
            type="text"
            name="titulo"
            value="{{tarea.titulo}}"
            required
            class="input-momo"
        >

    </div>

    <div class="campo-momo">

        <label>
            DESCRIPCIÓN
        </label>

        <textarea
            name="descripcion"
            class="textarea-momo"
        >{{tarea.descripcion}}</textarea>

    </div>

    <div class="campo-momo">

        <label>
            MATERIA
        </label>

        <select
            name="materia_id"
            class="input-momo"
        >

            {{#each materias}}

                <option value="{{this.id}}">
                    {{this.nombre}}
                </option>

            {{/each}}

        </select>

    </div>

    <div class="campo-momo">

        <label>
            FECHA DE ENTREGA
        </label>

        <input
            type="datetime-local"
            name="fecha_entrega"
            value="{{tarea.fecha_entrega}}"
            class="input-momo"
        >

    </div>

    <div class="campo-momo">

        <label>
            ESTADO
        </label>

        <select
            name="estado"
            class="input-momo"
        >

            <option value="pendiente">
                Pendiente
            </option>

            <option value="completada">
                Completada
            </option>

        </select>

    </div>

    <button
        type="submit"
        class="btn-momo"
    >
        GUARDAR CAMBIOS
    </button>

</form>


</div>
