<div class="formulario-momo">

```
<h1 class="titulo-formulario">
    EDITAR MATERIA
</h1>

<form
    action="/materias/editar/{{materia.id}}"
    method="POST"
    class="form-momo"
>

    <div class="campo-momo">

        <label for="nombre">
            NOMBRE DE LA MATERIA
        </label>

        <input
            type="text"
            name="nombre"
            id="nombre"
            value="{{materia.nombre}}"
            required
            class="input-momo"
        >

    </div>

    <div class="campo-momo">

        <label for="profesor">
            PROFESOR
        </label>

        <input
            type="text"
            name="profesor"
            id="profesor"
            value="{{materia.profesor}}"
            class="input-momo"
        >

    </div>

    <div class="campo-momo">

        <label for="color">
            COLOR DE LA MATERIA
        </label>

        <input
            type="color"
            name="color"
            id="color"
            value="{{materia.color}}"
            class="input-color-momo"
        >

    </div>

    <button
        type="submit"
        class="btn-momo"
    >
        GUARDAR CAMBIOS
    </button>

</form>
```

</div>
